# OpenGlaze Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control.

# =============================================================================
# REQUIRED
# =============================================================================

DATABASE_URL=sqlite:///glaze.db
BASE_URL=http://localhost:8768
FLASK_ENV=development

# =============================================================================
# DOCKER COMPOSE (only needed for docker-compose up)
# =============================================================================

POSTGRES_PASSWORD=change-me-in-production

# =============================================================================
# AUTHENTICATION (optional — only needed for multi-user mode)
# =============================================================================

KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://localhost:4434
KRATOS_HOOK_KEY=change-me-in-production

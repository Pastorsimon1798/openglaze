# OpenGlaze Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# =============================================================================
# REQUIRED
# =============================================================================

DATABASE_PATH=glaze.db
OPENGLAZE_MODE=personal
FLASK_HOST=127.0.0.1
FLASK_PORT=8767
FLASK_DEBUG=true
SECRET_KEY=

# =============================================================================
# OPTIONAL — General
# =============================================================================

# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:8767
# RATELIMIT_PER_MINUTE=60
# TRUSTED_PROXY=

# =============================================================================
# DOCKER COMPOSE (only needed for docker-compose up with Postgres)
# =============================================================================

# POSTGRES_HOST=
# POSTGRES_PASSWORD=

# =============================================================================
# CLOUD MODE (only needed when OPENGLAZE_MODE=cloud)
# =============================================================================

# HTTPS_ENFORCE=true
# SESSION_COOKIE_SECURE=true
# RATELIMIT_STORAGE_URL=redis://localhost:6379
# KRATOS_PUBLIC_URL=http://localhost:4433
# KRATOS_ADMIN_URL=http://localhost:4434
# ORY_KRATOS_ENDPOINT=http://localhost:4433
# ORY_KRATOS_ADMIN_ENDPOINT=http://localhost:4434
# DEMO_MODE=false

# =============================================================================
# AI ASSISTANT (Kama) — optional
# =============================================================================

# AI_PROVIDER=lmstudio
# LM_STUDIO_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_MODEL=
# LM_STUDIO_API_KEY=

# AI_PROVIDER=ollama
# OLLAMA_API=http://localhost:11434/api/chat
# OLLAMA_MODEL=kimi-k2.5:cloud

# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenGlaze Environment Configuration
# Copy this file to .env and fill in values before production use.

# =============================================================================
# DEFAULT SINGLE-USER SELF-HOST MODE
# =============================================================================

OPENGLAZE_MODE=personal
BASE_URL=http://localhost:8768
FLASK_HOST=0.0.0.0
FLASK_PORT=8768
FLASK_ENV=production
DATABASE_PATH=/data/glaze.db
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Optional local AI assistant provider
AI_PROVIDER=ollama
OLLAMA_API=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=kimi-k2.5:cloud
AI_TIMEOUT=90

# Optional hardening
RATELIMIT_PER_MINUTE=60
SESSION_COOKIE_SECURE=false

# =============================================================================
# EXPERIMENTAL CLOUD/MULTI-USER SERVICES
# =============================================================================
# PostgreSQL/Ory services are present in docker-compose under the `cloud` profile,
# but the current app data layer is SQLite-backed. Do not advertise this as the
# production path until PostgreSQL access is implemented end-to-end.

POSTGRES_HOST=postgres
POSTGRES_PASSWORD=change-me
KRATOS_HOOK_KEY=change-me
KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://localhost:4434
